# API keys and secrets — never bake into image layers
.env

# Version control metadata. Keep .git's refs (HEAD/refs/packed-refs, ~KB) in the
# build context so the Dockerfile can bake the commit ref into the image; exclude
# .git/objects (the ~100MB+ bulk) and the lfs cache — the ref parse never needs them.
.git/objects
.git/lfs
.gitignore
.github

# Local config — mounted read-only at runtime via compose.yaml
config/config.toml
config/config.bigsign.example.toml
config/config.firebird.example.toml

# Python build artifacts
__pycache__
*.pyc
*.pyo
*.egg-info
.venv
dist/
build/

# Development tools and tests
tests/
tools/
docs/
.claude/

# Editor/OS files
.DS_Store
*.swp
*.swo
