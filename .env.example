# led-ticker environment variables
# Copy this to .env and fill in your API keys.

# Required for the weather.current plugin — free key at https://www.weatherapi.com/ (free tier is plenty)
# WEATHERAPI_KEY=

# Web UI / busy-light auth tokens (preferred over the config.toml `token` fields;
# required to enable the web config editor — see the web-status-ui docs).
LED_TICKER_WEB_TOKEN=
LED_TICKER_BUSY_TOKEN=

# Optional — crypto.coingecko plugin (higher rate limit): https://www.coingecko.com/en/api/pricing
# COINGECKO_API_KEY=

# Optional — pool.monitor plugin (InfluxDB v2 connection)
# INFLUXDB_URL=
# INFLUXDB_TOKEN=
# INFLUXDB_ORG=
# INFLUXDB_BUCKET=
