      "sources": [
        {
          "type": "git",
          "url": "https://github.com/JamesAwesome/led-ticker-baseball",
          "ref": "main"
        }
      ]
    },
    {
      "name": "crypto",
      "namespace": "crypto",
      "summary": "CoinGecko cryptocurrency price ticker.",
      "homepage": "https://github.com/JamesAwesome/led-ticker-crypto",
      "provides": ["crypto.coingecko"],
      "sources": [
        {
          "type": "git",
          "url": "https://github.com/JamesAwesome/led-ticker-crypto",
          "ref": "main"
        }
      ]
    },
    {
      "name": "calendar",
